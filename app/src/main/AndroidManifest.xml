<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for listing installed apps (sideload-only, not subject to Play policy) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Granted manually in Settings → Apps → Special app access → Usage access -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Granted manually in Settings → Apps → Special app access → Display over other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Exact alarms for window-boundary precision (API 33+, pre-granted) -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Boot broadcast to re-arm alarms after restart -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization exemption dialog -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".LockdApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LockDapp">


        <activity
            android:name=".ui.block.BlockActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Lockd.Block" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LockDapp"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- Core blocking engine — the system keeps this alive as long as the
             user has granted accessibility permission. No separate foreground
             service needed in v1. -->
        <service
            android:name=".service.BlockAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Re-arms AlarmManager window-boundary alarms after a device reboot. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Fires at each window start/end to catch the "already inside" edge case
             with precision. Package-explicit intent; no need to be exported. -->
        <receiver
            android:name=".service.AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.lockdapp.ACTION_WINDOW_BOUNDARY" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
